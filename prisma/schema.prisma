// schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

//---------------------------------------------------------
// ENUMS (map to existing Postgres enums)
//---------------------------------------------------------

enum OrgRole {
  owner
  admin
  user
  viewer

  @@map("org_role")
}

enum MemberStatus {
  invited
  active

  @@map("member_status")
}

//---------------------------------------------------------
// TRANSACTION ENUMS
//---------------------------------------------------------

enum TransactionStatus {
  OK
  REVIEW
  NOK
  ERROR
}

enum TransactionEnvironment {
  test
  live
}

enum TransactionExecutionMode {
  single
  bulk
}

//---------------------------------------------------------
// USERS TABLE
//---------------------------------------------------------

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String  @map("password_hash")
  fullName     String? @map("full_name")
  country      String?
  twofaEnabled Boolean @default(false) @map("twofa_enabled")
  twofaSecret  String? @map("twofa_secret")

  passwordResetTokens PasswordResetToken[]
  emailVerifiedAt     DateTime?            @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  organizationsCreated Organization[]       @relation("OrganizationsCreatedBy")
  sessions             Session[]
  organizationMembers  OrganizationMember[]
  invitedMembers       OrganizationMember[] @relation("MemberInvitedBy")
  favoriteServices     FavoriteService[]
  transactions         Transaction[]
  creditWallet         CreditWallet?

  emailVerificationTokens EmailVerificationToken[]

  lastActiveOrgId  Int?     @map("last_active_org_id")

  // admin/internal access
  isAdmin       Boolean   @default(false) @map("is_admin")
  adminRole     String?   @map("admin_role")

  // platform control
  isBlocked     Boolean   @default(false) @map("is_blocked")
  blockedAt     DateTime? @map("blocked_at")
  blockedUntil  DateTime? @map("blocked_until")
  blockedReason String?   @map("blocked_reason")
  deletedAt     DateTime? @map("deleted_at")

  adminSessions AdminSession[]

  @@map("users")
}

//---------------------------------------------------------
// ORGANIZATIONS TABLE
//---------------------------------------------------------

model Organization {
  id          Int     @id @default(autoincrement())
  orgUid      String  @unique @map("org_uid")
  name        String
  createdBy   Int     @map("created_by")
  teamEnabled Boolean @default(false) @map("team_enabled")

  // ✅ Keep these because they exist in your DB right now
  // (prevents Prisma from trying to drop them)
  billingEmail   String? @map("billing_email")
  billingCountry String? @map("billing_country")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  // Relations
  createdByUser    User                 @relation("OrganizationsCreatedBy", fields: [createdBy], references: [id])
  members          OrganizationMember[]
  sessions         Session[]            @relation("ActiveOrgSessions")
  favoriteServices FavoriteService[]
  transactions     Transaction[]
  creditWallet     CreditWallet?

  @@map("organizations")
}

//---------------------------------------------------------
// SESSIONS TABLE
//---------------------------------------------------------

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  sessionToken String   @unique @map("session_token")
  activeOrgId  Int?     @map("active_org_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  expiresAt    DateTime @map("expires_at")

  // Relations
  user      User          @relation(fields: [userId], references: [id])
  activeOrg Organization? @relation("ActiveOrgSessions", fields: [activeOrgId], references: [id])

  @@map("sessions")
}

//---------------------------------------------------------
// ORGANIZATION MEMBERS TABLE
//---------------------------------------------------------

model OrganizationMember {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  userId         Int?         @map("user_id")
  email          String
  name           String?
  role           OrgRole      @map("role")
  status         MemberStatus @default(invited) @map("status")
  invitedBy      Int?         @map("invited_by")
  invitedAt      DateTime     @default(now()) @map("invited_at")
  joinedAt       DateTime?    @map("joined_at")

  organization  Organization @relation(fields: [organizationId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])
  invitedByUser User?        @relation("MemberInvitedBy", fields: [invitedBy], references: [id])

  // ✅ add this
  inviteToken OrganizationInviteToken?

  @@unique([organizationId, userId], name: "org_member_user_unique")
  @@unique([organizationId, email], name: "org_member_email_unique")
  @@map("organization_members")
}


model FavoriteService {
  id        Int    @id @default(autoincrement())
  serviceId String @map("service_id")

  userId         Int? @map("user_id")
  organizationId Int? @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([serviceId, userId])
  @@unique([serviceId, organizationId])
  @@map("favorite_services")
}

model Transaction {
  id String @id @default(uuid())

  // Ownership
  userId         Int  @map("user_id")
  organizationId Int? @map("organization_id")

  // Classification
  service String
  status  TransactionStatus

  environment   TransactionEnvironment
  executionMode TransactionExecutionMode

  batchId String? @map("batch_id")

  // Timing
  createdAt  DateTime @default(now()) @map("created_at")
  durationMs Int      @map("duration_ms")

  // Payloads
  request  Json
  response Json

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  // Indexes
  @@index([userId])
  @@index([organizationId])
  @@index([service])
  @@index([status])
  @@index([createdAt])
  @@index([batchId])
  @@map("transactions")
}

//---------------------------------------------------------
// BILLING ENUMS
//---------------------------------------------------------
enum CreditTxnType {
  topup
  usage
  adjustment

  @@map("credit_txn_type")
}

enum CreditTxnSource {
  stripe
  internal

  @@map("credit_txn_source")
}

//---------------------------------------------------------
// SERVICES (DB-defined pricing)
//---------------------------------------------------------
model Service {
  id                 Int                   @id @default(autoincrement())
  key                String                @unique
  name               String
  description        String?
  priceCredits       Int                   @map("price_credits")
  features           Json?
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @default(now()) @map("updated_at")
  creditTransactions CreditTransaction[]
  countryPrices      ServiceCountryPrice[]
  operationPrices    ServiceOperationPrice[]

  @@map("services")
}
model ServiceOperationPrice {
  id           Int      @id @default(autoincrement())
  serviceId    Int      @map("service_id")
  operationKey String   @map("operation_key")
  priceCredits Int      @map("price_credits")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, operationKey], name: "service_operation_unique")
  @@index([serviceId])
  @@index([operationKey])
  @@map("service_operation_prices")
}
//---------------------------------------------------------
// CREDIT WALLET (org OR user)
//---------------------------------------------------------
model CreditWallet {
  id             Int  @id @default(autoincrement())
  userId         Int? @unique @map("user_id")
  organizationId Int? @unique @map("organization_id")

  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  transactions   CreditTransaction[]
  billingProfile BillingProfile?

  @@map("credit_wallets")
}

//---------------------------------------------------------
// CREDIT LEDGER
//---------------------------------------------------------
model CreditTransaction {
  id       String          @id @default(uuid())
  walletId Int             @map("wallet_id")
  type     CreditTxnType
  source   CreditTxnSource @default(internal)
  delta    Int

  serviceId     Int?    @map("service_id")
  umbrellaTxnId String? @map("umbrella_txn_id")
  description   String?

  stripeEventId           String? @map("stripe_event_id")
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  stripeInvoiceId         String? @map("stripe_invoice_id")

  // ✅ NEW: invoice links + display data
  stripeInvoiceHostedUrl  String?  @map("stripe_invoice_hosted_url")
  stripeInvoicePdfUrl     String?  @map("stripe_invoice_pdf_url")
  amountCents             Int?     @map("amount_cents")
  currency                String?  @map("currency")
  stripeInvoiceNumber     String?  @map("stripe_invoice_number")
  stripeInvoiceStatus     String?  @map("stripe_invoice_status")

  stripeReceiptUrl String? @map("stripe_receipt_url")
  stripeChargeId   String? @map("stripe_charge_id")

  createdAt DateTime @default(now()) @map("created_at")

  wallet  CreditWallet @relation(fields: [walletId], references: [id])
  service Service?     @relation(fields: [serviceId], references: [id])

  @@index([walletId, createdAt])
  @@index([serviceId])
  @@index([umbrellaTxnId])
  @@map("credit_transactions")
}

//---------------------------------------------------------
// STRIPE CUSTOMER MAPPING
//---------------------------------------------------------
enum BillingType {
  personal
  company

  @@map("billing_type")
}

model BillingProfile {
  id Int @id @default(autoincrement())

  walletId Int @unique @map("wallet_id")

  stripeCustomerId String? @unique @map("stripe_customer_id")

  billingType BillingType @map("billing_type")

  email String @map("billing_email")

  fullName String? @map("billing_full_name")

  companyName String? @map("company_name")

  vatNumber String? @map("tax_id")

  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String? @map("city")
  postalCode   String? @map("postal_code")
  country      String  @map("country")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  wallet CreditWallet @relation(fields: [walletId], references: [id])

  @@map("billing_profiles")
}

model ServiceCountryPrice {
  id          Int      @id @default(autoincrement())
  serviceId   Int      @map("service_id")
  countryCode String   @map("country_code")
  priceEur    Decimal  @map("price_eur") @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, countryCode], name: "service_country_unique")
  @@index([serviceId])
  @@index([countryCode])
  @@map("service_country_prices")
}

model ComplianceConsent {
  id             Int    @id @default(autoincrement())
  ownerKind      String
  userId         Int?
  organizationId Int?

  key         String
  countryCode String
  tncVersion  String
  reason      String
  acceptedAt  DateTime @default(now())

  @@unique([ownerKind, userId, organizationId, key, countryCode, tncVersion], name: "ownerKind_userId_organizationId_key_countryCode_tncVersion")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
model OrganizationInviteToken {
  id        String    @id @default(uuid())
  memberId  Int       @unique @map("member_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("organization_invite_tokens")
}

//---------------------------------------------------------
// ADMIN CONSOLE
//---------------------------------------------------------

model AdminSession {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  sessionTokenHash String   @unique @map("session_token_hash")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")
  expiresAt        DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_sessions")
}